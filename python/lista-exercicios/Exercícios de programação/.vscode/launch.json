{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug C Program",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/a.out",  // caminho para o executável gerado
      "args": [],                            // argumentos de linha de comando (se precisar)
      "stopAtEntry": false,                  // parar na entrada do programa?
      "cwd": "${workspaceFolder}",           // diretório de trabalho
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",                      // debugger para Linux/macOS
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}